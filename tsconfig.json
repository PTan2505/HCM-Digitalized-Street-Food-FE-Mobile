{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    /* STRICT SAFETY (Matches Web) */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true,
    /* RELAXED DEV RULES (Matches Web) */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "ignoreDeprecations": "6.0",
    /* PATH ALIASES (Matches Web) */
    "baseUrl": "./src",
    "paths": {
      "@assets/*": ["assets/*"],
      "@customer-app/*": ["apps/customer/*"],
      "@manager-app/*": ["apps/manager/*"],
      "@screens/*": ["screens/*"],
      "@components/*": ["components/*"],
      "@contexts/*": ["contexts/*"],
      "@hooks/*": ["hooks/*"],
      "@lib/*": ["lib/*"],
      "@custom-types/*": ["types/*"],
      "@utils/*": ["utils/*"],
      "@config/*": ["config/*"],
      "@slices/*": ["slices/*"],
      "@constants/*": ["constants/*"],
      "@features/*": ["features/*"],
      "@auth/*": ["features/auth/*"],
      "@user/*": ["features/user/*"],
      "@manager/*": ["features/manager/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".eslintrc.js",
    "eslint.config.js",
    "nativewind-env.d.ts",
    "images.d.ts",
    "plugins/withAndroidDebugKeystore.cjs"
  ]
}
