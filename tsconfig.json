{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    /* STRICT SAFETY (Matches Web) */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true,
    /* RELAXED DEV RULES (Matches Web) */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    /* PATH ALIASES (Matches Web) */
    "paths": {
      "@customer-app/*": ["./src/apps/customer/*"],
      "@manager-app/*": ["./src/apps/manager/*"],
      "@screens/*": ["./src/screens/*"],
      "@customer/*": ["./src/features/customer/*"],
      "@manager/*": ["./src/features/manager/*"],
      "@assets/*": ["./src/assets/*"],
      "@app/*": ["./src/app/*"],
      "@components/*": ["./src/components/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@lib/*": ["./src/lib/*"],
      "@custom-types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"],
      "@config/*": ["./src/config/*"],
      "@slices/*": ["./src/slices/*"],
      "@constants/*": ["./src/constants/*"],
      "@features/*": ["./src/features/*"],
      "@auth/*": ["./src/features/auth/*"],
      "@user/*": ["./src/features/user/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".eslintrc.js",
    "eslint.config.js",
    "nativewind-env.d.ts",
    "images.d.ts",
    "plugins/withAndroidDebugKeystore.cjs"
  ]
}
