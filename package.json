{
  "name": "hcm-digitalized-street-food-fe-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "check:bundle": "expo export -p ios --no-bytecode --output-dir dist-check && expo export -p android --no-bytecode --output-dir dist-check",
    "generate": "orval",
    "strip-ios-push": "node -e \"const fs=require('fs'),p='ios/Lowca/Lowca.entitlements';if(fs.existsSync(p)){const c=fs.readFileSync(p,'utf8').replace(/\\s*<key>aps-environment<\\/key>\\s*<string>[^<]*<\\/string>/g,'');fs.writeFileSync(p,c);console.log('Stripped aps-environment from entitlements')}\"",
    "prebuild:ios": "expo prebuild --platform ios && bun run strip-ios-push",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:android": "bun run prebuild:android && eas build --platform android --profile development --local",
    "build:ios": "bun run prebuild:ios && eas build --platform ios --profile development --local"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@microsoft/signalr": "^10.0.0",
    "@ptomasroos/react-native-multi-slider": "^2.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.91.2",
    "axios": "^1.13.2",
    "expo": "~54.0.30",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-localization": "^17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "^6.0.8",
    "i18next": "^25.7.3",
    "link": "^2.1.1",
    "lottie-react-native": "~7.3.1",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.1",
    "prop-types": "^15.8.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^16.5.1",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.1",
    "react-native-fbsdk-next": "^13.4.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-otp-entry": "^1.8.5",
    "react-native-progress-steps": "^2.0.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-reanimated-carousel": "^5.0.0-beta.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "reactotron-react-native": "^5.1.18",
    "validator": "^13.15.26",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "~19.1.0",
    "@types/validator": "^13.15.10",
    "ajv": "^8.18.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "orval": "^8.5.3",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-native-svg-transformer": "^1.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "6",
    "typescript-eslint": "^8.58.0"
  },
  "private": true
}
